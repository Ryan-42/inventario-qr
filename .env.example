# ─── BACKEND — copie para backend/.env ───────────────────────

# Banco de dados
# Desenvolvimento (SQLite, sem Docker):
DATABASE_URL=sqlite:///./inventario.db
# Produção (Neon PostgreSQL):
# DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/inventario_db?sslmode=require

# CORS — URLs do frontend separadas por vírgula
ALLOWED_ORIGINS=http://localhost:3000
# Produção: ALLOWED_ORIGINS=https://inventario-qr.vercel.app

# Claude AI — necessário para validação de planilha com IA
# Obtenha em: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-coloque-sua-chave-aqui

# Segurança (gere com: openssl rand -hex 32)
SECRET_KEY=mude-para-uma-chave-forte-e-aleatoria-min-32-chars

# Ambiente
APP_ENV=development


# ─── FRONTEND — configure no painel do Vercel ────────────────

# URL do backend Railway (server-side — rewrites Next.js)
# BACKEND_URL=https://inventario-qr-backend.railway.app

# URL do backend Railway (client-side — WebSocket)
# NEXT_PUBLIC_BACKEND_URL=https://inventario-qr-backend.railway.app
