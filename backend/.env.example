# Copie este arquivo para .env e preencha os valores
# cp .env.example .env  (Linux/Mac)
# copy .env.example .env  (Windows)

# Banco de dados
# Dev (SQLite -- padrao, sem configuracao necessaria)
DATABASE_URL=sqlite:///./inventario.db

# Producao (PostgreSQL)
# DATABASE_URL=postgresql://usuario:senha@host:5432/inventario_qr

# IA -- Anthropic Claude (opcional -- sem a chave, usa analise local)
ANTHROPIC_API_KEY=sk-ant-...

# CORS -- origens permitidas (separar por virgula)
ALLOWED_ORIGINS=http://localhost:8000,http://192.168.1.10:8000

# Seguranca (a implementar -- EV-01)
# SECRET_KEY=sua-chave-secreta-minimo-32-caracteres
