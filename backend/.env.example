# ─────────────────────────────────────────────────────────────────────────────
# INVIQ — Configuração de Ambiente
# Copie: cp .env.example .env  e preencha os valores
# ─────────────────────────────────────────────────────────────────────────────

# ── Ambiente ──────────────────────────────────────────────────────────────────
# development | production
APP_ENV=development


# ── Banco de Dados ─────────────────────────────────────────────────────────────
# Dev (SQLite — padrão, sem configuração necessária)
DATABASE_URL=sqlite:///./inventario.db

# Produção (PostgreSQL obrigatório quando APP_ENV=production)
# DATABASE_URL=postgresql://usuario:senha_segura@host:5432/inventario_qr


# ── PostgreSQL (apenas para docker-compose.prod.yml) ──────────────────────────
POSTGRES_USER=inviq
POSTGRES_PASSWORD=GERE_UMA_SENHA_SEGURA_AQUI
POSTGRES_DB=inventario_qr


# ── Redis ─────────────────────────────────────────────────────────────────────
# Usado para rate limiting (slowapi) e cache futuro
REDIS_URL=redis://localhost:6379/0
# Produção: redis://:SENHA@redis:6379/0
REDIS_PASSWORD=GERE_UMA_SENHA_REDIS_AQUI


# ── Segurança ─────────────────────────────────────────────────────────────────
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=SUBSTITUA_POR_CHAVE_SEGURA_MINIMO_32_CHARS

# Em produção, gere um SECRET_KEY forte e NÃO use o valor padrão!

# TRUST_PROXY: defina como true APENAS quando um proxy reverso confiável (nginx/caddy/cloudflare)
# for o único ponto de entrada. Quando true, o IP é lido do header X-Forwarded-For.
# Quando false (padrão), usa request.client.host — protege contra IP spoofing via header.
TRUST_PROXY=false


# ── IA — Governança de dados ──────────────────────────────────────────────────
# AI_ENABLED=true permite que agentes usem APIs externas (Anthropic/Groq).
# false (padrão) — todos os agentes operam em modo local mesmo com chave configurada.
# Consulte a seção "Governança de dados e LGPD" no README antes de habilitar.
AI_ENABLED=false


# ── IA (Claude / Anthropic) ───────────────────────────────────────────────────
# Opcional — sem a chave, análises usam modo local simplificado
# Obtenha em: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...


# ── CORS ─────────────────────────────────────────────────────────────────────
# Origens permitidas, separadas por vírgula
# Dev:
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000,http://192.168.1.10:8000
# Prod: substitua pelo domínio real
# ALLOWED_ORIGINS=https://inventario.suaempresa.com.br


# ── Performance (produção) ────────────────────────────────────────────────────
# Número de workers do gunicorn (recomendado: 2 × núcleos + 1)
GUNICORN_WORKERS=2


# ─────────────────────────────────────────────────────────────────────────────
# CHECKLIST DE PRODUÇÃO
# ─────────────────────────────────────────────────────────────────────────────
# [ ] APP_ENV=production
# [ ] DATABASE_URL com PostgreSQL
# [ ] SECRET_KEY com pelo menos 32 chars aleatórios
# [ ] POSTGRES_PASSWORD e REDIS_PASSWORD com senhas fortes
# [ ] ALLOWED_ORIGINS apenas com domínios reais (sem localhost)
# [ ] ANTHROPIC_API_KEY configurada (para análise IA funcionar)
# [ ] HTTPS configurado no proxy reverso (nginx/caddy/cloudflare)
